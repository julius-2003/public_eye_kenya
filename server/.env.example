# ⚙️ SERVER CONFIGURATION
NODE_ENV=development
PORT=5000

# 🗄️ DATABASE - MongoDB Connection
# Local: mongodb://localhost:27017/publiceye
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/publiceye
MONGO_URI=mongodb://localhost:27017/publiceye

# 🔐 JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 👤 Admin Configuration
SUPERADMIN_EMAIL=admin@publiceye.org

# 📧 Email Service (Disabled - Nodemailer removed for now)
# To enable, add EMAIL_HOST, EMAIL_PORT, EMAIL_USER, EMAIL_PASS, EMAIL_FROM

# 💰 M-Pesa Payment Gateway (Daraja API)
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-m-pesa-passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/support/callback

# 📱 Organization Details
POCHI_PHONE=254702199939
TILL_NUMBER=552341

# 🌐 Frontend URL (for CORS & Email Links)
CLIENT_URL=http://localhost:5173